{
    "providers": {
        "openrouter": {
            "apiKey": "${OPENROUTER_API_KEY}"
        },
        "custom": {
            "apiKey": "${CEREBRAS_API_KEY}",
            "apiBase": "https://api.cerebras.ai/v1/chat/completions"
        }
    },
    "agents": {
        "defaults": {
            "model": "gpt-oss-120b",
            "provider": "custom",
            "temperature": 0.7,
            "maxTokens": 2048
        }
    },
    "channels": {
        "telegram": {
            "enabled": false,
            "token": "${TELEGRAM_BOT_TOKEN}",
            "allowFrom": ["*"]
        }
    },
    "tools": {
        "restrictToWorkspace": true
    }
}